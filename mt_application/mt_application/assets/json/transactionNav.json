{
  "type": "set_value",
  "args": {
    "values": {
      "entries": {
        "values": "${transaction}"
      },
      "template": {
        "type": "padding",
        "args": {
          "padding": 10,
          "child": {
            "type": "gesture_detector",
            "args": {
              "child": {
                "type": "card",
                "args": {
                  "margin": {
                    "type": "edge_insets",
                    "args": {
                      "vertical": 8,
                      "horizontal": 16
                    }
                  },
                  "child": {
                    "type": "padding",
                    "args": {
                      "padding": 16,
                      "child": {
                        "type": "row",
                        "args": {
                          "mainAxisAlignment": "spaceBetween",
                          "children": [
                            {
                              "type": "expanded",
                              "args": {
                                "child": {
                                  "type": "column",
                                  "args": {
                                    "crossAxisAlignment": "start",
                                    "children": [
                                      {
                                        "type": "text",
                                        "args": {
                                          "text": "${value['SERVICENAME']}",
                                          "style": {
                                            "fontSize": 18,
                                            "fontWeight": "bold"
                                          }
                                        }
                                      },
                                      {
                                        "type": "sized_box",
                                        "args": {
                                          "height": 4
                                        }
                                      },
                                      {
                                        "type": "text",
                                        "args": {
                                          "text": "${value['DESCRIPTION']}",
                                          "maxLines": 2,
                                          "overflow": "ellipsis",
                                          "style": {
                                            "fontSize": 16
                                          }
                                        }
                                      },
                                      {
                                        "type": "sized_box",
                                        "args": {
                                          "height": 4
                                        }
                                      },
                                      {
                                        "type": "row",
                                        "args": {
                                          "children": [
                                            {
                                              "type": "text",
                                              "args": {
                                                "text": "TRANSID: ",
                                                "style": {
                                                  "fontSize": 14
                                                }
                                              }
                                            },
                                            {
                                              "type": "text",
                                              "args": {
                                                "text": "${value['TRANSID']}",
                                                "style": {
                                                  "fontSize": 14
                                                }
                                              }
                                            }
                                          ]
                                        }
                                      },
                                      {
                                        "type": "sized_box",
                                        "args": {
                                          "height": 4
                                        }
                                      },
                                      {
                                        "type": "row",
                                        "args": {
                                          "children": [
                                            {
                                              "type": "text",
                                              "args": {
                                                "text": "${value['DATE']}",
                                                "style": {
                                                  "fontSize": 14
                                                }
                                              }
                                            },
                                            {
                                              "type": "sized_box",
                                              "args": {
                                                "width": 8
                                              }
                                            },
                                            {
                                              "type": "text",
                                              "args": {
                                                "text": "${value['TIME']}",
                                                "style": {
                                                  "fontSize": 14
                                                }
                                              }
                                            }
                                          ]
                                        }
                                      }
                                    ]
                                  }
                                }
                              }
                            },
                            {
                              "type": "column",
                              "args": {
                                "crossAxisAlignment": "end",
                                "children": [
                                  {
                                    "type": "text",
                                    "args": {
                                      "text": "${value['AMOUNT']}",
                                      "style": {
                                        "fontSize": 18,
                                        "color": "#000000",
                                        "fontWeight": "bold"
                                      }
                                    }
                                  },
                                  {
                                    "type": "sized_box",
                                    "args": {
                                      "height": 20
                                    }
                                  },
                                  {
                                    "type": "text",
                                    "args": {
                                      "text": "${value['STATUS']}",
                                      "style": {
                                        "fontSize": 16,
                                        "fontWeight": "bold",
                                        "color": "${value['STATUS']=='Failed'?'#FF0000':'#00FF00'}"
                                      }
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "child": {
      "type": "scaffold",
      "args": {
        "appBar": {
          "type": "app_bar",
          "args": {
            "backgroundColor": "#F4511E",
            "title": {
              "type": "row",
              "args": {
                "children": [
                  {
                    "type": "icon",
                    "args": {
                      "icon": {
                        "codePoint": "0xe0a5",
                        "fontFamily": "MaterialIcons"
                      },
                      "color": "#FFFFFF",
                      "size": 30
                    }
                  },
                  {
                    "type": "text",
                    "args": {
                      "text": "Transaction History",
                      "style": {
                        "color": "#FFFFFF"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "body": {
          "type": "padding",
          "args": {
            "padding": [
              20,
              20,
              20,
              20
            ],
            "child": {
              "type": "column",
              "args": {
                "children": [
                  {
                    "type": "row",
                    "args": {
                      "children": [
                        {
                          "type": "expanded",
                          "args": {
                            "child": {
                              "type": "text_form_field",
                              "args": {
                                "readOnly": true,
                                "onTap": "${selectFromDate()}",
                                "controller": "${fromDateController}",
                                "decoration": {
                                  "labelText": "From Date",
                                  "hintText": "Select From Date"
                                }
                              }
                            }
                          }
                        },
                        {
                          "type": "sized_box",
                          "args": {
                            "width": 16
                          }
                        },
                        {
                          "type": "expanded",
                          "args": {
                            "child": {
                              "type": "text_form_field",
                              "args": {
                                "readOnly": true,
                                "onTap": "${selectToDate()}",
                                "controller": "${toDateController}",
                                "decoration": {
                                  "labelText": "To Date",
                                  "hintText": "Select To Date"
                                }
                              }
                            }
                          }
                        }
                      ]
                    }
                  },
                  {
                    "type": "sized_box",
                    "args": {
                      "height": 16
                    }
                  },
                  {
                    "type": "elevated_button",
                    "args": {
                      "onPressed": "${TEST()}",
                      "style": {
                        "backgroundColor": "#f4511e"
                      },
                      "child": {
                        "type": "text",
                        "args": {
                          "text": "Go",
                          "style": {
                            "color": "#FFFFFF",
                            "fontWeight": "bold",
                            "fontSize": 20
                          }
                        }
                      }
                    }
                  },
                  {
                    "type": "sized_box",
                    "args": {
                      "height": 10
                    }
                  },
                  {
                    "type": "center",
                    "args": {
                      "child": {
                        "type": "text",
                        "args": {
                          "text": "You can search a maximum of 60 days",
                          "style": {
                            "fontSize": 20,
                            "color": "#f4511e"
                          }
                        }
                      }
                    }
                  },
                  {
                    "type": "sized_box",
                    "args": {
                      "height": 10
                    }
                  },
                  {
                    "type": "container",
                    "args": {
                      "height": 1.0,
                      "color": "#e0e0e0"
                    }
                  },
                  {
                    "type": "sized_box",
                    "args": {
                      "height": 10
                    }
                  },
                  {
                    "type": "expanded",
                    "args": {
                      "child": {
                        "type": "list_view",
                        "listen": [
                          "entries"
                        ],
                        "args": {
                          "children": "${for_each(entries['values'], 'template')}"
                        }
                      }
                    }
                  },
                  {
                    "type": "sized_box",
                    "args": {
                      "height": 10
                    }
                  },
                  {
                    "type": "center",
                    "args": {
                      "child": {
                        "type": "text",
                        "args": {
                          "text": "${tansactionHistoryData}",
                          "style": {
                            "fontSize": 20,
                            "color": "#f4511e"
                          }
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}