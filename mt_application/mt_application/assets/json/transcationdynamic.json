{
    "type": "set_value",
    "args": {
      "values": {
        "entries": {
          "values": "${transaction}"
        },
        "template": {
          "type": "card",
          "args": {
            "height": 5,
            "borderRadius": {
              "type": "all",
              "radius": 8
            },
            "margin": {
              "top": 3,
              "bottom": 1,
              "left": 13,
              "right": 13
            },
            "color": "#FFFFFF",
            "child": {
              "type": "list_tile",
              "args": {
                "title": {
                  "type": "text",
                  "args": {
                    "text": "${value['title']}",
                    "style": {
                      "fontSize": 13
                    }
                  }
                },
                "subtitle": {
                  "type": "column",
                  "args": {
                    "crossAxisAlignment": "start",
                    "children": [
                      {
                        "type": "text",
                        "args": {
                          "text": "${value['msisdn']}",
                          "style": {
                            "fontSize": 12,
                            "fontWeight": "bold"
                          }
                        }
                      },
                      {
                        "type": "text",
                        "args": {
                          "text": "${value['date']}",
                          "style": {
                            "fontSize": 11
                          }
                        }
                      }
                    ]
                  }
                },
                "leading": {
                  "type": "sized_box",
                  "args": {
                    "width": 40,
                    "height": 60,
                    "child": {
                      "type": "column",
                      "args": {
                        "children": [
                          {
                            "type": "preferred_size",
                            "args": {
                              "preferredSize": 20,
                              "child": {
                                "type": "asset_image",
                                "args": {
                                  "name": "assets/images/bt/recharge.png",
                                  "height": 40,
                                  "width": 40,
                                  "fit": "fill"
                                }
                              }
                            }
                          },
                          {
                            "type": "sized_box",
                            "args": {
                              "height": 1
                            }
                          },
                          {
                            "type": "text",
                            "args": {
                              "text": "${value['status']}",
                              "style": {
                                "fontSize": 10,
                                "color": "${value['status']=='Failed!'?'#FF0000':'#00FF00'}"
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                },
                "trailing": {
                  "type": "sized_box",
                  "args": {
                    "width": 80,
                    "child": {
                      "type": "column",
                      "args": {
                        "children": [
                          {
                            "type": "text",
                            "args": {
                              "text": "${value['price']}",
                              "style": {
                                "fontSize": 12,
                                "fontWeight": "bold"
                              }
                            }
                          },
                          {
                            "type": "sized_box",
                            "args": {
                              "height": 15
                            }
                          },
                          {
                            "type": "row",
                            "args": {
                              "children": [
                                {
                                  "type": "text",
                                  "args": {
                                    "text": "${value['type']}",
                                    "style": {
                                      "fontSize": 12
                                    }
                                  }
                                },
                                {
                                  "type": "sized_box",
                                  "args": {
                                    "width": 10
                                  }
                                },
                                {
                                  "type": "preferred_size",
                                  "args": {
                                    "preferredSize": 10,
                                    "child": {
                                      "type": "asset_image",
                                      "args": {
                                        "name": "assets/images/bt/walet.png",
                                        "height": 20,
                                        "width": 20,
                                        "fit": "fill"
                                      }
                                    }
                                  }
                                }
                              ]
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "child": {
        "type": "scaffold",
        "args": {
          "body": {
            "type": "stack",
            "args": {
              "children": [
                {
                  "type": "container",
                  "args": {
                    "color": "#D6D6D6",
                    "height": "infinity",
                    "width": "infinity"
                  }
                },
                {
                  "type": "preferred_size",
                  "args": {
                    "preferredSize": 1000,
                    "child": {
                      "type": "asset_image",
                      "args": {
                        "name": "assets/images/bt/appbar.png",
                        "height": 250,
                        "width": "infinity",
                        "fit": "fill"
                      }
                    }
                  }
                },
                {
                  "type": "positioned",
                  "args": {
                    "top": 100,
                    "left": 10,
                    "right": 10,
                    "child": {
                      "type": "list_tile",
                      "args": {
                        "title": {
                          "type": "center",
                          "args": {
                            "child": {
                              "type": "text",
                              "args": {
                                "text": "Transaction History",
                                "style": {
                                  "color": "#FFFFFF",
                                  "fontWeight": "bold",
                                  "fontSize": 18
                                }
                              }
                            }
                          }
                        },
                        "leading": {
                          "type": "icon_button",
                          "args": {
                            "icon": {
                              "type": "icon",
                              "args": {
                                "color": "#FFFFFF",
                                "icon": {
                                  "codePoint": "0xe092",
                                  "fontFamily": "MaterialIcons"
                                }
                              }
                            }
                          }
                        },
                        "trailing": {
                          "type": "icon_button",
                          "args": {
                            "icon": {
                              "type": "icon",
                              "args": {
                                "color": "#FFFFFF",
                                "icon": {
                                  "codePoint": "0xe309",
                                  "fontFamily": "MaterialIcons",
                                  "size": 100
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "type": "positioned",
                  "args": {
                    "top": 150,
                    "left": 5,
                    "right": 5,
                    "bottom": 0,
                    "child": {
                      "type": "card",
                      "args": {
                        "elevation": 5,
                        "shadowColor": "#000000",
                        "decoration": {
                          "color": "#D6D6D6",
                          "border": {
                            "all": 20
                          }
                        },
                        "height": 200,
                        "child": {
                          "type": "column",
                          "args": {
                            "crossAxisAlignment": "start",
                            "children": []
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "type": "positioned",
                  "args": {
                    "top": 170,
                    "left": 25,
                    "right": 20,
                    "bottom": 300,
                    "child": {
                      "type": "single_child_scroll_view",
                      "args": {
                        "child": {
                          "type": "row",
                          "args": {
                            "children": [
                              {
                                "type": "container",
                                "args": {
                                  "child": {
                                    "type": "column",
                                    "args": {
                                      "crossAxisAlignment": "start",
                                      "children": [
                                        {
                                          "type": "row",
                                          "args": {
                                            "children": [
                                              {
                                                "type": "sized_box",
                                                "args": {
                                                  "width": 20
                                                }
                                              },
                                              {
                                                "type": "text",
                                                "args": {
                                                  "text": "From",
                                                  "style": {
                                                    "color": "#000000",
                                                    "fontWeight": "bold"
                                                  }
                                                }
                                              }
                                            ]
                                          }
                                        },
                                        {
                                          "type": "card",
                                          "args": {
                                            "elevation": 5,
                                            "shadowColor": "#000000",
                                            "color": "#FFFFFF",
                                            "decoration": {
                                              "borderRadius": 8.0
                                            },
                                            "child": {
                                              "type": "container",
                                              "args": {
                                                "width": 140,
                                                "height": 50,
                                                "child": {
                                                  "type": "row",
                                                  "args": {
                                                    "children": [
                                                      {
                                                        "type": "sized_box",
                                                        "args": {
                                                          "width": 5
                                                        }
                                                      },
                                                      {
                                                        "type": "asset_image",
                                                        "args": {
                                                          "name": "assets/images/bt/calender.png",
                                                          "height": 30,
                                                          "width": 25,
                                                          "fit": "fill"
                                                        }
                                                      },
                                                      {
                                                        "type": "sized_box",
                                                        "args": {
                                                          "width": 8
                                                        }
                                                      },
                                                      {
                                                        "type": "expanded",
                                                        "args": {
                                                          "child": {
                                                            "type": "container",
                                                            "args": {
                                                              "child": {
                                                                "type": "text_form_field",
                                                                "args": {
                                                                  "readOnly": true,
                                                                  "onTap": "${selectFromDate()}",
                                                                  "controller": "${fromDateController}",
                                                                  "decoration": {
                                                                    "border": "${border}"
                                                                  }
                                                                }
                                                              }
                                                            }
                                                          }
                                                        }
                                                      }
                                                    ]
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      ]
                                    }
                                  }
                                }
                              },
                              {
                                "type": "sized_box",
                                "args": {
                                  "width": 16
                                }
                              },
                              {
                                "type": "container",
                                "args": {
                                  "child": {
                                    "type": "column",
                                    "args": {
                                      "crossAxisAlignment": "start",
                                      "children": [
                                        {
                                          "type": "row",
                                          "args": {
                                            "children": [
                                              {
                                                "type": "sized_box",
                                                "args": {
                                                  "width": 20
                                                }
                                              },
                                              {
                                                "type": "text",
                                                "args": {
                                                  "text": "To",
                                                  "style": {
                                                    "color": "#000000",
                                                    "fontWeight": "bold"
                                                  }
                                                }
                                              }
                                            ]
                                          }
                                        },
                                        {
                                          "type": "card",
                                          "args": {
                                            "elevation": 5,
                                            "shadowColor": "#000000",
                                            "color": "#FFFFFF",
                                            "decoration": {
                                              "borderRadius": 8.0
                                            },
                                            "child": {
                                              "type": "container",
                                              "args": {
                                                "width": 140,
                                                "height": 50,
                                                "child": {
                                                  "type": "row",
                                                  "args": {
                                                    "children": [
                                                      {
                                                        "type": "sized_box",
                                                        "args": {
                                                          "width": 5
                                                        }
                                                      },
                                                      {
                                                        "type": "asset_image",
                                                        "args": {
                                                          "name": "assets/images/bt/calender.png",
                                                          "height": 30,
                                                          "width": 25,
                                                          "fit": "fill"
                                                        }
                                                      },
                                                      {
                                                        "type": "sized_box",
                                                        "args": {
                                                          "width": 8
                                                        }
                                                      },
                                                      {
                                                        "type": "expanded",
                                                        "args": {
                                                          "child": {
                                                            "type": "container",
                                                            "args": {
                                                              "child": {
                                                                "type": "text_form_field",
                                                                "args": {
                                                                  "readOnly": true,
                                                                  "onTap": "${selectToDate()}",
                                                                  "controller": "${toDateController}",
                                                                  "decoration": {
                                                                    "border": "${border}"
                                                                  }
                                                                }
                                                              }
                                                            }
                                                          }
                                                        }
                                                      }
                                                    ]
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      ]
                                    }
                                  }
                                }
                              }
                            ]
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "type": "positioned",
                  "args": {
                    "child": {
                      "type": "column",
                      "args": {
                        "children": [
                          {
                            "type": "container",
                            "args": {
                              "color": "#FFFFFF",
                              "elevation": 2,
                              "shadowColor": "#000000",
                              "width": 400,
                              "height": 50,
                              "alignment": "center",
                              "child": {
                                "type": "row",
                                "args": {
                                  "mainAxisAlignment": "center",
                                  "crossAxisAlignment": "start",
                                  "children": [
                                    {
                                      "type": "text",
                                      "args": {
                                        "text": "Jun 2024",
                                        "style": {
                                          "fontSize": 16,
                                          "fontWeight": "bold",
                                          "color": "#000000"
                                        }
                                      }
                                    }
                                  ]
                                }
                              }
                            }
                          }
                        ]
                      }
                    },
                    "top": 280,
                    "left": 10,
                    "right": 10,
                    "bottom": 0
                  }
                },
                {
                  "type": "positioned",
                  "args": {
                    "child": {
                      "type": "expanded",
                      "args": {
                        "child": {
                          "type": "list_view",
                          "listen": [
                            "entries"
                          ],
                          "args": {
                            "children": "${for_each(entries['values'], 'template')}"
                          }
                        }
                      }
                    },
                    "top": 300,
                    "left": 0,
                    "right": 0,
                    "bottom": 0
                  }
                }
              ]
            }
          }
        }
      }
    }
  }