{
    "type": "scaffold",
    "args": {
       "appBar": {
          "type": "preferred_size",
          "args": {
             "preferredSize": 250,
             "child": {
                "type": "stack",
                "args": {
                   "children": [
                      {
                         "type": "asset_image",
                         "args": {
                            "name": "assets/images/bt/appbar.png",
                            "height": 250,
                            "fit": "fill"
                         }
                      },
                      {
                         "type": "positioned",
                         "args": {
                            "left": 10,
                            "top": 10,
                            "bottom": 10,
                            "right": 10,
                            "child": {
                               "type": "list_tile",
                               "args": {
                                  "title": {
                                     "type": "center",
                                     "args": {
                                        "child": {
                                           "type": "text",
                                           "args": {
                                              "text": "B-Tunes",
                                              "style": {
                                                 "color": "#000000",
                                                 "fontWeight": "bold"
                                              }
                                           }
                                        }
                                     }
                                  },
                                  "leading": {
                                     "type": "icon_button",
                                     "args": {
                                        "color": "#FFFFFF",
                                        "icon": {
                                           "type": "icon",
                                           "args": {
                                              "icon": {
                                                 "codePoint": 58712,
                                                 "fontFamily": "MaterialIcons"
                                              }
                                           }
                                        }
                                     }
                                  },
                                  "trailing": {
                                     "type": "icon_button",
                                     "args": {
                                        "icon": {
                                           "type": "icon",
                                           "args": {
                                              "icon": {
                                                 "codePoint": 61912,
                                                 "fontFamily": "MaterialIcons",
                                                 "size": 50
                                              }
                                           }
                                        }
                                     }
                                  }
                               }
                              
                            }
                         }
                      }
                   ]
                }
             }
          }
       },
       "body": {
          "type": "center",
          "args": {
             "child":  {
               "type": "positioned",
               "args": {
                 "top": 300,
                 "left": 100,
                 "right": 100,
                 "child": {
                   "type": "elevated_button",
                   "args": {
                     "onPressed": "${print()}",
                     "style": {
                       "backgroundColor": "#1C3144",
                       "shape":{ 
                         "type":"rectangle",
                         "args": {
                           "borderRadius": {
                             "type": "circular",
                             "args": {
                               "radius": 20
                             }
                           }
                         }
                       }
   
                     },
                     "child": {
                       "type": "text",
                       "args": {
                         "text": "Go",
                         "style": {
                           "color": "#FFFFFF",
                           "fontWeight": "bold",
                           "fontSize": 20
                         }
                       }
                     },
                     "width": 200,
                     "height": 50
                   }
                 }
               }
             }
          }
       }
    }
 }